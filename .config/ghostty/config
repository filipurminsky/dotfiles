theme = Catppuccin Mocha
# Nerd Font Mono variant (NFM): full icon set, glyphs constrained to one cell
# for clean alignment in yazi/nvim. Installed via the JetBrainsMono Nerd Font.
font-family = "JetBrainsMono NFM"

# Vim-style scrollback navigation
keybind = ctrl+shift+b=scroll_page_up
keybind = ctrl+shift+f=scroll_page_down
keybind = ctrl+shift+u=scroll_page_fractional:-0.5
keybind = ctrl+shift+d=scroll_page_fractional:0.5
