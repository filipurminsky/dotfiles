# Catppuccin Mocha styleset for aerc.
# Adapted from the bundled `catppuccin` (Frappé) styleset to the Mocha palette
# (https://catppuccin.com/palette) to match the Neovim theme.
# vim: ft=dosini

*.default=true
*.normal=true

default.fg=#cdd6f4
default.bg=#1e1e2e

error.fg=#f38ba8
warning.fg=#fab387
success.fg=#a6e3a1

tab.fg=#6c7086
tab.bg=#181825
tab.selected.fg=#cdd6f4
tab.selected.bg=#1e1e2e
tab.selected.bold=true

border.fg=#11111b
border.bold=true

msglist_unread.bold=true
msglist_flagged.fg=#f9e2af
msglist_flagged.bold=true
msglist_result.fg=#89b4fa
msglist_result.bold=true
# Selected row: Mauve accent (base-colored text on mauve) so the cursor pops.
msglist_*.selected.bold=true
msglist_*.selected.fg=#1e1e2e
msglist_*.selected.bg=#cba6f7

# Marked rows (multi-select via Space / v): Yellow bg so marks stand out;
# Peach when a marked row is also the cursor.
msglist_marked.fg=#1e1e2e
msglist_marked.bg=#f9e2af
msglist_marked.bold=true
msglist_marked.selected.fg=#1e1e2e
msglist_marked.selected.bg=#fab387

dirlist_*.selected.bold=true
dirlist_*.selected.fg=#1e1e2e
dirlist_*.selected.bg=#cba6f7

statusline_default.fg=#9399b2
statusline_default.bg=#313244
statusline_error.bold=true
statusline_success.bold=true

completion_default.selected.bg=#313244

part_filename.selected.fg=#cdd6f4
part_filename.selected.bg=#1e1e2e
part_switcher.selected.bg=#1e1e2e

part_mimetype.selected.fg=#cdd6f4
part_mimetype.selected.bg=#1e1e2e

selector_focused.bg=#1e1e2e

[viewer]
url.fg=#89b4fa
url.underline=true
header.bold=true
signature.dim=true
diff_meta.bold=true
diff_chunk.fg=#89b4fa
diff_chunk_func.fg=#89b4fa
diff_chunk_func.bold=true
diff_add.fg=#a6e3a1
diff_del.fg=#f38ba8
quote_*.fg=#6c7086
quote_1.fg=#9399b2
